{
  "_comment": [
    "Conservative pre-approved allow-list for Claude Code.",
    "",
    "Anything in this list = a tool call Claude can run without asking. The kit",
    "ships a deliberately tight default: read-only inspections, system status,",
    "git/docker queries. Anything that mutates state, fetches remote code",
    "(curl|bash), or touches sensitive paths (~/.ssh, /etc/shadow, ...) is",
    "INTENTIONALLY absent — those keep prompting on every invocation.",
    "",
    "Edit this file locally to widen the list if it gets annoying for you. To",
    "re-merge into ~/.claude/settings.json after editing:",
    "  python scripts/install-permissions-allowlist.py data/permissions-allowlist.json"
  ],
  "permissions": {
    "allow": [
      "Read(./**)",
      "Read(/tmp/**)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(awk *)",
      "Bash(sed -n *)",
      "Bash(jq *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(date *)",
      "Bash(uname *)",
      "Bash(hostname *)",
      "Bash(uptime *)",
      "Bash(whoami *)",
      "Bash(id *)",
      "Bash(pwd *)",
      "Bash(ps *)",
      "Bash(ss -tln*)",
      "Bash(ss -uln*)",
      "Bash(df -h*)",
      "Bash(du -sh*)",
      "Bash(free -h*)",
      "Bash(pgrep *)",
      "Bash(systemctl status *)",
      "Bash(systemctl is-*)",
      "Bash(systemctl list-*)",
      "Bash(journalctl --no-pager *)",
      "Bash(tailscale status*)",
      "Bash(tailscale ip *)",
      "Bash(tailscale ping *)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch*)",
      "Bash(git remote -v*)",
      "Bash(git fetch *)",
      "Bash(docker ps*)",
      "Bash(docker logs *)",
      "Bash(docker images*)",
      "Bash(curl --head *)",
      "Bash(curl -I *)",
      "Bash(timeout *)",
      "Bash(sleep *)",
      "Bash(test *)"
    ]
  }
}
