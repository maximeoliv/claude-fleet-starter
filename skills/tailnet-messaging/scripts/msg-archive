#!/usr/bin/env python3
"""msg-archive — mark transfer(s) as read by moving them inbox → archive.

Usage:
  msg-archive <transfer-id>      # archive one transfer
  msg-archive --all              # archive all inbox transfers
  msg-archive --json <id>        # machine-readable

A claude code, after processing a received transfer, should call:
  msg-archive <transfer-id>
so the unread counter drops accordingly.
"""
from __future__ import annotations

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from msg_lib import (  # noqa: E402
    INBOX, archive_transfer, archive_transfer_anywhere,
    ensure_dirs, inbox_count, list_transfers,
)


def main():
    ensure_dirs()
    as_json = "--json" in sys.argv
    argv = [a for a in sys.argv[1:] if a != "--json"]

    archived, failed = [], []

    if "--all" in argv:
        for t in list_transfers(INBOX):
            (archived if archive_transfer(t["id"]) else failed).append(t["id"])
    elif argv:
        for tid in argv:
            (archived if archive_transfer_anywhere(tid) else failed).append(tid)
    else:
        print("Usage: msg-archive <transfer-id> | --all", file=sys.stderr)
        sys.exit(1)

    if as_json:
        print(json.dumps({"archived": archived, "failed": failed,
                          "inbox_remaining": inbox_count()}))
        return

    for tid in archived:
        print(f"✓ archivé: {tid}")
    for tid in failed:
        print(f"✗ introuvable dans inbox: {tid}")
    print(f"Compteur inbox: {inbox_count()} transfert(s) restant(s)")


if __name__ == "__main__":
    main()
