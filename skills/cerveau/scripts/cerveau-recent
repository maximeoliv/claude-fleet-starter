#!/usr/bin/env python3
"""cerveau-recent — show recent changes in cerveau-flotte.

Usage:
  cerveau-recent [N_days]    # default: 7 days
"""
import subprocess
import sys
from pathlib import Path

REPO = Path.home() / "cerveau-flotte"


def main():
    n_days = int(sys.argv[1]) if len(sys.argv) > 1 else 7

    if not REPO.exists():
        print(f"ERROR: cerveau-flotte not cloned at {REPO}", file=sys.stderr)
        sys.exit(1)

    # Pull first to make sure we have the latest from origin
    subprocess.run(["git", "-C", str(REPO), "fetch", "origin", "--quiet"], timeout=10)

    # git log with --since and origin/main to include unpulled commits
    r = subprocess.run(
        ["git", "-C", str(REPO), "log", "--pretty=format:%h|%ai|%an|%s",
         "--name-only", f"--since={n_days} days ago", "origin/main"],
        capture_output=True, text=True, timeout=10,
    )
    if r.returncode != 0:
        print(f"ERROR: git log failed: {r.stderr}", file=sys.stderr)
        sys.exit(1)

    if not r.stdout.strip():
        print(f"Aucun changement dans cerveau-flotte sur les {n_days} derniers jours.")
        return

    print(f"Changements cerveau-flotte sur les {n_days} derniers jours :\n")

    blocks = r.stdout.strip().split("\n\n")
    for block in blocks:
        lines = block.strip().splitlines()
        if not lines:
            continue
        header = lines[0]
        if "|" not in header:
            continue
        sha, date, author, subject = header.split("|", 3)
        files = [l for l in lines[1:] if l.strip()]
        print(f"  {date[:16]}  {sha}  {author}")
        print(f"      {subject}")
        for f in files:
            print(f"        • {f}")
        print()


if __name__ == "__main__":
    main()
