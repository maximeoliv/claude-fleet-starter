#!/usr/bin/env python3
"""msg-sent-show — display a sent transfer.

Usage:
  msg-sent-show <transfer-id>           # show content
  msg-sent-show <transfer-id> --json    # machine-readable (incl. status)
"""
from __future__ import annotations

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from msg_lib import get_sent_content, get_sent_status  # noqa: E402


def main():
    args = [a for a in sys.argv[1:] if a != "--json"]
    as_json = "--json" in sys.argv
    if not args:
        print("Usage: msg-sent-show <transfer-id> [--json]", file=sys.stderr)
        sys.exit(2)
    tid = args[0]
    content = get_sent_content(tid)
    if not content:
        print(f"Aucun envoi nommé '{tid}' dans ~/taildrops-envoyes/.",
              file=sys.stderr)
        sys.exit(1)
    status = get_sent_status(tid) or {}
    if as_json:
        out = {**content, "status_tracker": status}
        print(json.dumps(out, indent=2, ensure_ascii=False))
        return

    print(f"Sent transfer {tid}")
    print(f"  to       : {content.get('to')}")
    print(f"  subject  : {content.get('subject')}")
    print(f"  priority : {content.get('priority')}")
    if content.get("in_reply_to"):
        print(f"  in_reply_to : {content['in_reply_to']}")
    if status:
        print(f"  status   : {status.get('status')}  (replies={len(status.get('replies', []))}"
              f", receipts={len(status.get('receipts', []))})")
        print(f"  updated  : {status.get('updated_at')}")
    print("─" * 60)
    print(content.get("message_text") or "(empty)")


if __name__ == "__main__":
    main()
